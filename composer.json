{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cboxdk/laravel-billing-stripe",
    "description": "Cbox Billing — Stripe payment-gateway adapter: a PaymentGateway implementation backed by Stripe, for cboxdk/laravel-billing.",
    "keywords": ["cbox", "billing", "payments", "stripe", "gateway", "laravel"],
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "../laravel-billing", "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.4",
        "cboxdk/laravel-billing": "@dev",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "stripe/stripe-php": "^20.3"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.5 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\Billing\\Stripe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\Billing\\Stripe\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "analyse": "phpstan analyse --no-progress --memory-limit=1G",
        "test": "pest",
        "license-check": "@php bin/check-licenses.php",
        "sbom": "@php bin/generate-sbom.php",
        "qa": ["@lint", "@analyse", "@test", "@license-check", "@composer audit"]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\Billing\\Stripe\\StripeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
